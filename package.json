{
  "name": "dep-lens-monorepo",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "workspaces": [
    "packages/dep-lens"
  ],
  "scripts": {
    "build": "npm run build:core && npm run build:cli",
    "build:core": "cargo build --release",
    "build:cli": "npm run build --workspace @lunanoir/dep-lens",
    "test": "npm run test:core && npm run test:cli",
    "test:core": "cargo test",
    "test:cli": "npm run test --workspace @lunanoir/dep-lens",
    "lint": "cargo clippy --all-targets -- -D warnings && cargo fmt --check"
  }
}
